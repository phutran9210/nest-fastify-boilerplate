# App
NODE_ENV=development
PORT=3000
# Pino log level (fatal|error|warn|info|debug|trace|silent). Bỏ trống → debug (dev) / info (prod).
# LOG_LEVEL=debug
# Ghi log ra file (ngoài console). Xoay theo ngày, giữ LOG_FILE_MAX_DAYS file gần nhất.
LOG_FILE_ENABLED=false
# Ghi thêm file chỉ chứa lỗi (level >= error), độc lập với LOG_FILE_ENABLED.
LOG_ERROR_FILE_ENABLED=false
LOG_DIR=logs
LOG_FILE_MAX_DAYS=30
# Kích thước tối đa mỗi file log — xoay khi vượt (vd 50m, 1g).
LOG_FILE_MAX_SIZE=50m

# Database (Prisma / PostgreSQL) — host port 5433 to avoid conflicts
DATABASE_URL=postgresql://app:app@localhost:5433/app?schema=public

# Redis (BullMQ) — host port 6380 to avoid conflicts
REDIS_HOST=localhost
REDIS_PORT=6380

# Worker process (BullMQ) — chạy độc lập với API: `pnpm start:worker:dev`
# Cổng HTTP của worker (health + Bull Board), độc lập với PORT của API.
WORKER_PORT=3001
# Số job mail chạy song song.
MAIL_WORKER_CONCURRENCY=5
# Basic Auth cho Bull Board UI (/admin/queues, chỉ trên worker).
BULLBOARD_USER=admin
# BẮT BUỘC ở production (app worker không boot nếu thiếu). Dev bỏ trống → fallback 'admin'.
# Đặt giá trị mạnh trước khi deploy.
BULLBOARD_PASSWORD=change-me-in-production

# RabbitMQ — host port 5673 (mgmt UI 15673) to avoid conflicts
RABBITMQ_URL=amqp://guest:guest@localhost:5673
RABBITMQ_EXCHANGE=app
RABBITMQ_PREFETCH=10
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAYS_MS=5000,30000,300000
RABBITMQ_QUORUM_DELIVERY_LIMIT=5
RABBITMQ_IDEMPOTENCY_TTL=86400
RABBITMQ_OUTBOX_POLL_MS=1000
RABBITMQ_OUTBOX_BATCH=50
RABBITMQ_OUTBOX_MAX_ATTEMPTS=10

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600
