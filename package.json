{
  "name": "nest-fastify",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "start:worker": "nest start --entryFile main.worker",
    "start:worker:dev": "nest start --watch --entryFile main.worker",
    "start:worker:prod": "node dist/src/main.worker.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "i18n:gen": "nestjs-i18n -p src/i18n -o src/generated/i18n.generated.ts --include-subfolders",
    "i18n:gen:watch": "nestjs-i18n -p src/i18n -o src/generated/i18n.generated.ts --include-subfolders --watch",
    "verify": "pnpm i18n:gen && pnpm check && pnpm typecheck && pnpm build",
    "test": "jest",
    "logs": "cat logs/app.*.log | pino-pretty",
    "logs:tail": "tail -n+1 -f logs/app.*.log | pino-pretty",
    "logs:err": "cat logs/app.*.log | jq -c 'select(.level>=50)' | pino-pretty",
    "logs:warn": "cat logs/app.*.log | jq -c 'select(.level>=40)' | pino-pretty",
    "logs:errfile": "cat logs/error.*.log | pino-pretty",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "private": true,
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/fastify": "^7.1.5",
    "@bull-board/nestjs": "^7.1.5",
    "@fastify/static": "^9.1.3",
    "@golevelup/nestjs-rabbitmq": "^9.0.2",
    "@js-temporal/polyfill": "^0.5.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "better-auth": "^1.6.20",
    "bullmq": "^5.78.0",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fastify": "5.8.5",
    "ioredis": "^5.11.1",
    "nestjs-i18n": "^10.8.4",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  }
}
